# Copy to .env (auto-loaded by agentkit) or export these in your shell.

# ── Pick your provider ───────────────────────────────────────────────────
# local (default) | anthropic | openai | gemini
MODEL_PROVIDER=local

# ── Local model endpoint (any OpenAI-compatible server) ──────────────────
# Ollama default shown (deterministic port). Pull the house model first:
#   ollama pull granite4:micro     (~2 GB; the event's Granite, tool-capable, fast)
# Podman AI Lab: Services → your model service → copy the port, e.g.
#   LOCAL_BASE_URL=http://localhost:35463/v1   and usually   LOCAL_MODEL=granite
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL=granite4:micro

# ── Frontier keys (only needed for the provider you pick) ────────────────
# ANTHROPIC_API_KEY=sk-ant-...   # https://console.anthropic.com
# OPENAI_API_KEY=sk-...          # https://platform.openai.com
# GEMINI_API_KEY=...             # https://aistudio.google.com (free tier)

# ── Optional ─────────────────────────────────────────────────────────────
# TAVILY_API_KEY=tvly-...        # chief-of-stuff live research (optional)
# AGENT_OFFLINE=1                # force fixtures everywhere (evals set this)
# AGENTKIT_MODEL=...             # override the default-tier model id
# AGENTKIT_STRONG_MODEL=...      # override the strong-tier model id
# AGENTKIT_CHEAP_MODEL=...       # override the cheap-tier model id
